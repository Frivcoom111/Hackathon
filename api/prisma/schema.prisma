generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Address {
  id            String         @id @default(uuid())
  street        String
  number        String
  complement    String?
  district      String
  city          String
  state         String         @db.VarChar(2)
  zipCode       String         @db.VarChar(10)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company?
  companyMember CompanyMember?
  student       Student?
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  role          Role           @default(STUDENT)
  isActive      Boolean        @default(true)
  totpSecret    String?
  totpEnabled   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyMember CompanyMember?
  notifications Notification[]
  student       Student?
}

model Course {
  id             String          @id @default(uuid())
  name           String          @unique
  code           String?         @unique
  periods        Int
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  jobs           Job[]
  studentCourses StudentCourse[]
}

model Student {
  id           String          @id @default(uuid())
  userId       String          @unique
  addressId    String?         @unique
  name         String
  ra           String          @unique
  cpf          String          @unique @db.VarChar(11)
  phone        String?         @db.VarChar(11)
  isEligible   Boolean         @default(true)
  resumePath   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  applications Application[]
  certificates Certificate[]
  address      Address?        @relation(fields: [addressId], references: [id])
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses      StudentCourse[]
}

model Certificate {
  id          String   @id @default(uuid())
  studentId   String
  name        String
  institution String?
  issuedAt    DateTime
  filePath    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId], map: "Certificate_studentId_fkey")
}

model StudentCourse {
  id         String              @id @default(uuid())
  studentId  String
  courseId   String
  status     StudentCourseStatus @default(ACTIVE)
  startedAt  DateTime
  finishedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  course     Course              @relation(fields: [courseId], references: [id])
  student    Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId], map: "StudentCourse_courseId_fkey")
}

model Company {
  id          String          @id @default(uuid())
  addressId   String?         @unique
  name        String
  cnpj        String          @unique @db.VarChar(14)
  description String          @db.Text
  phone       String          @db.VarChar(11)
  status      CompanyStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  address     Address?        @relation(fields: [addressId], references: [id])
  members     CompanyMember[]
  jobs        Job[]
}

model CompanyMember {
  id        String            @id @default(uuid())
  companyId String
  userId    String            @unique
  addressId String?           @unique
  role      CompanyMemberRole @default(RECRUITER)
  name      String
  cpf       String            @unique @db.VarChar(11)
  phone     String?           @db.VarChar(11)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  address   Address?          @relation(fields: [addressId], references: [id])
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model Job {
  id           String        @id @default(uuid())
  companyId    String
  courseId     String?
  title        String
  description  String        @db.Text
  area         String
  requirements String?       @db.Text
  salary       Float?
  location     String
  modality     Modality      @default(PRESENCIAL)
  status       JobStatus     @default(ACTIVE)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  course       Course?       @relation(fields: [courseId], references: [id])

  @@index([companyId], map: "Job_companyId_fkey")
  @@index([courseId], map: "Job_courseId_fkey")
}

model Application {
  id          String            @id @default(uuid())
  studentId   String
  jobId       String
  status      ApplicationStatus @default(PENDING)
  resumePath  String?
  coverLetter String?           @db.Text
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
  @@index([jobId], map: "Application_jobId_fkey")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Notification_userId_fkey")
}

enum Role {
  ADMIN
  COMPANY
  STUDENT
}

enum CompanyStatus {
  PENDING
  ANALYSING
  APPROVED
  BLOCKED
}

enum CompanyMemberRole {
  ADMIN
  RECRUITER
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum Modality {
  PRESENCIAL
  REMOTE
  HYBRID
}

enum ApplicationStatus {
  PENDING
  ANALYSING
  APPROVED
  REJECTED
  CANCELLED
}

enum StudentCourseStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}
